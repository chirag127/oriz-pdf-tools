---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FAMILY } from '~/lib/family'
const key = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title="contact — oriz / pdf-tools"
  description="Get in touch about pdf.oriz.in — bug reports, feature requests, partnerships."
  pageNum="ii"
>
  <div class="page-head">
    <p class="eyebrow"><a href="/">tools</a> / contact</p>
    <h1>Contact.</h1>
    <p class="lede">
      Bug, idea, or an implement you wish existed? Email is fastest:
      <a href={`mailto:${FAMILY.operator.email}`}><strong>{FAMILY.operator.email}</strong></a>.
    </p>
  </div>

  <hr data-section="i" />

  <section class="prose">
    <p>
      Since every tool runs entirely in your browser, I can't see your files
      or recover them — but I can fix bugs, ship missing implements, and
      answer anything else. The form below posts to Web3Forms which forwards
      to my inbox; nothing about the message is stored on this site.
    </p>

    <form action="https://api.web3forms.com/submit" method="POST" class="contact-form">
      <input type="hidden" name="access_key" value={key} />
      <input type="hidden" name="subject" value="pdf.oriz.in contact form" />
      <input type="hidden" name="from_name" value="pdf.oriz.in contact form" />
      <input type="text" name="name" placeholder="Your name" required />
      <input type="email" name="email" placeholder="Your email" required />
      <textarea name="message" placeholder="Your message" required></textarea>
      <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
      <button type="submit">Send</button>
    </form>

    <p class="meta">
      For privacy questions or DMCA notices, see the
      <a href="/legal/grievance/">grievance officer</a> page (mandatory under
      IT Rules 2021).
    </p>
  </section>
</BaseLayout>
